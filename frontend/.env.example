# Frontend environment variables
# Copy this file to .env and adjust values

# Cockpit CMS API URL (backend)
VITE_API_URL=http://localhost:3030

# Placeholder image for menu items without an image
VITE_PLACEHOLDER_IMAGE=placeholder.webp

# Set to "true" to show demo banner + demo accounts on login page
VITE_DEMO_SERVER=false

# Cockpit CMS asset URL prefix (for menu/category images)
VITE_ASSET_URL=http://localhost:3030/storage/uploads
