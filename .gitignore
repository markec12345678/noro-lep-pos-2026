# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
**/dist/
build/
**/build/

# Environment
.env
.env.local
.env.*.local
**/.env
**/.env.local

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.sublime-*

# Docker
*.local

# Cockpit storage (keep structure, ignore data)
backend/storage/data/*.sqlite
backend/storage/tmp/*
!backend/storage/data/.gitkeep
!backend/storage/tmp/.gitkeep

# Mini-services
mini-services/*/node_modules/
mini-services/*/dist/

# Lock files (keep bun.lockb, ignore others)
package-lock.json
yarn.lock
